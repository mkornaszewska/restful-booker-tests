<component name="ProjectRunConfigurationManager">
  <configuration default="false" name="Run All Tests" type="JUnit" factoryName="JUnit">
    <module name="restful-booker" />
    <extension name="coverage">
      <pattern>
        <option name="PATTERN" value="com.kornaszewska.tests.auth.*" />
        <option name="ENABLED" value="true" />
      </pattern>
    </extension>
    <option name="PACKAGE_NAME" value="com.kornaszewska.tests" />
    <option name="MAIN_CLASS_NAME" value="" />
    <option name="METHOD_NAME" value="" />
    <option name="TEST_OBJECT" value="package" />
    <dir value="$PROJECT_DIR$/src/test" />
    <method v="2">
      <option name="Make" enabled="true" />
    </method>
  </configuration>
</component>